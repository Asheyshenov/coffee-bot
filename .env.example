# Coffee Bot Environment Configuration
# Copy this file to .env and fill in your values

# ========================================
# Telegram Bot Configuration
# ========================================
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ========================================
# Database Configuration
# ========================================
# SQLite (for development):
DATABASE_URL=sqlite://db/development.sqlite3

# PostgreSQL (for production):
# DATABASE_URL=postgres://username:password@localhost:5432/coffee_bot

# ========================================
# Barista Access Control
# ========================================
# Comma-separated list of Telegram user IDs allowed to access barista panel
# Get your Telegram user ID from @userinfobot
BARISTA_WHITELIST=123456789,987654321

# ========================================
# Order Settings
# ========================================
# Minutes before unpaid invoice expires
ORDER_EXPIRE_MINUTES=15

# ========================================
# QRPay / O!Деньги Configuration (Legacy)
# ========================================
# API base URL (sandbox for testing, production for live)
QRPAY_BASE_URL=https://api.odengi.kg

# Your merchant credentials from O!Деньги
QRPAY_MERCHANT_ID=your_merchant_id
QRPAY_SECRET_KEY=your_secret_key

# ========================================
# MWallet API Configuration
# ========================================
# API base URL (test server for development)
MWALLET_BASE_URL=https://mw-api-test.dengi.kg/api/json/json.php

# Your service ID and password from MWallet
MWALLET_SID=your_sid
MWALLET_PASSWORD='your_password'  # Use quotes if password contains # or special chars

# API version (default: 1005)
# MWALLET_API_VERSION=1005

# Test mode (true for sandbox, false for production)
MWALLET_TEST_MODE=true

# ========================================
# Callback Configuration
# ========================================
# Public URL where payment providers will send callbacks
# This must be accessible from the internet
PUBLIC_BASE_URL=https://your-domain.com

# ========================================
# Payment Provider Timeouts (optional)
# ========================================
# Request timeout in seconds
# QRPAY_TIMEOUT_SECONDS=30
# MWALLET_TIMEOUT_SECONDS=30

# Number of retry attempts for failed requests
# QRPAY_RETRY_COUNT=3
# MWALLET_RETRY_COUNT=3

# ========================================
# Application Environment
# ========================================
# Set to 'production' for production deployment
RACK_ENV=development
